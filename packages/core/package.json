{
  "name": "@datoteca/core",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "PRNG determinístico y helpers compartidos para Datoteca",
  "keywords": [
    "prng",
    "seed",
    "seeded-random",
    "deterministic",
    "mulberry32",
    "random",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johansneirap/datoteca.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/johansneirap/datoteca/tree/main/packages/core#readme",
  "bugs": "https://github.com/johansneirap/datoteca/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "attw": "attw --pack ."
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
